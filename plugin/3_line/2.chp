# https://github.com/Zeronetsec/Chprompt

[Preview]
\x1b[0m\n
\x1b[1;30m
$(command date '+%Y-%m-%d %H:%M:%S')\n
\x1b[1;37m
~/$(command basename "$(pwd)")
%space%\x1b[1;30m\n
$(if [[ "${EUID}" -eq 0 ]]; then echo '#'; else echo '$'; fi)
\x1b[0m
[END]

[Execute]
\[\033[0m\]\n
\[\033[1;30m\]\D{%F %T}\n
\[\033[1;37m\]\w%space%
\[\033[1;30m\]\n
\$
\[\033[0m\]%space%
[END]

