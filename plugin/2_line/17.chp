# https://github.com/Zeronetsec/Chprompt

[Preview]
\x1b[0m\n
\x1b[1;36m(gh0st)
\x1b[0m%space%
\x1b[1;32m
$(command whoami)@$(command hostname)
\x1b[0m%space%::%space%
\x1b[1;35m
~/$(command basename "$(pwd)")
\x1b[0m\n
❯
[END]

[Execute]
\[\033[0m\]\n
\[\033[1;36m\](gh0st)
\[\033[0m\]%space%
\[\033[1;32m\]\u@\h
\[\033[0m\]%space%::%space%
\[\033[1;35m\]\w
\[\033[0m\]\n
❯%space%
[END]

