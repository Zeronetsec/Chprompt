# https://github.com/Zeronetsec/Chprompt

[Preview]
\x1b[0m\n
\x1b[1;32m
$(command whoami)
\x1b[0m@
\x1b[1;34m
$(command hostname)
\x1b[0m:
\x1b[1;33m
~/$(command basename "$(pwd)")
\x1b[0m\n
➜
[END]

[Execute]
\[\033[0m\]\n
\[\033[1;32m\]\u
\[\033[0m\]@
\[\033[1;34m\]\h
\[\033[0m\]:
\[\033[1;33m\]\w
\[\033[0m\]\n
➜%space%
[END]

