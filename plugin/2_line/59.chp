# https://github.com/Zeronetsec/Chprompt

[Preview]
\x1b[0m\n
\x1b[38;5;147m✦%space%
$(command whoami)@$(command hostname)
%space%✦\n
\x1b[38;5;110m✧%space%
~/$(command basename "$(pwd)")
%space%✧%space%➤
\x1b[0m
[END]

[Execute]
\[\033[0m\]\n
\[\033[38;5;147m\]✦%space%\u@\h%space%✦\n
\[\033[38;5;110m\]✧%space%\w%space%✧%space%➤
\[\033[0m\]%space%
[END]

