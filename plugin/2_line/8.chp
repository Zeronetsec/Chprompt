# https://github.com/Zeronetsec/Chprompt

[Preview]
\033[0m\n
\033[1;31m┌──(
\033[1;34m$(command whoami)
\033[1;30m㉿
\033[1;34m$(command hostname)
\033[1;31m)-(
\033[1;34m$(command date +%R)
\033[1;31m)-[
\033[0;33m~/$(command basename "$(pwd)")
\033[1;31m]\n
\033[1;31m└──
\033[1;30m
$(if [[ "$EUID" -eq 0 ]]; then echo '#'; else echo '$'; fi)
\033[0m
[END]

[Execute]
\[\033[0m\]\n
\[\033[1;31m\]┌──(
\[\033[1;34m\]\u
\[\033[1;30m\]㉿
\[\033[1;34m\]\h
\[\033[1;31m\])-(
\[\033[1;34m\]$(command date +%R)
\[\033[1;31m\])-[
\[\033[0;33m\]\w
\[\033[1;31m\]]\n
\[\033[1;31m\]└──
\[\033[1;30m\]\$
\[\033[0m\]
%space%
[END]

