# https://github.com/Zeronetsec/Chprompt

[Preview]
\033[0m\n
\033[1;45;97m%space%
$(command whoami)@$(command hostname)
%space%\033[0m%space%
\033[1;44;97m%space%
~/$(command basename "$(pwd)")
%space%\033[0m\n
$(if [[ "$EUID" -eq 0 ]]; then echo '#'; else echo '$'; fi)
[END]

[Execute]
\[\033[0m\]\n
\[\033[1;45;97m\]%space%\u@\h%space%
\[\033[0m\]%space%
\[\033[1;44;97m\]%space%\w%space%
\[\033[0m\]\n
\$%space%
[END]

