[Preview]
\033[0m\n
\033[38;5;160m刀%space%%space%
$(command whoami)@$(command hostname)\n
\033[38;5;81m刀%space%%space%
~/$(command basename "$(pwd)")
%space%❯
\033[0m
[END]

[Execute]
\[\033[0m\]\n
\[\033[38;5;160m\]
刀%space%%space%\u@\h\n
\[\033[38;5;81m\]
刀%space%%space%\w%space%❯
\[\033[0m\]%space%
[END]

