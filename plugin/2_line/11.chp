\[\033[0;34m\]┌──(
\[\033[0;32m\]\h
\[\033[0;34m\])
%space%\[\033[0;32m\]>
%space%\[\033[0;34m\](
\[\033[0;32m\]\w
\[\033[0;34m\])\n
\[\033[0;34m\]└──≫
\[\033[0m\]%space%
[END]

