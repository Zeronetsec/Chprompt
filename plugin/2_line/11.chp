[Preview]
\x1b[0m\n
\x1b[0;34m┌──(
\x1b[0;32m
$(command hostname)
\x1b[0;34m)
%space%\x1b[0;32m>
%space%\x1b[0;34m(
\x1b[0;32m
~/$(command basename "$(pwd)")
\x1b[0;34m)\n
\x1b[0;34m└──≫
\x1b[0m
[END]

[Execute]
