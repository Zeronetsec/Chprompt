# https://github.com/Zeronetsec/Chprompt

[Preview]
\x1b[0m\n
\x1b[0;32m
$(command whoami)@$(command hostname)
\x1b[0m%space%
\x1b[0;37m
~/$(command basename "$(pwd)")
\x1b[0m\n
>
[END]

[Execute]
\[\033[0m\]\n
\[\033[0;32m\]\u@\h
\[\033[0m\]%space%
\[\033[0;37m\]\w
\[\033[0m\]\n
>%space%
[END]

