# https://github.com/Zeronetsec/Chprompt

[Preview]
\033[0m\n
\033[1;34mDirectory:%space%
~/$(command basename "$(pwd)")\n
\033[1;32mUser:%space%
$(command whoami)
%space%\033[1;37m>>
\033[0m
[END]

[Execute]
\[\033[0m\]\n
\[\033[1;34m\]Directory:%space%\w\n
\[\033[1;32m\]User:%space%\u%space%
\[\033[1;37m\]>>
\[\033[0m\]%space%
[END]

