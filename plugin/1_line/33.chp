# https://github.com/Zeronetsec/Chprompt

[Preview]
\x1b[0m\n
\x1b[38;5;219m❖
%space%
$(command whoami)@$(command hostname)
%space%|%space%
~/$(command basename "$(pwd)")
%space%❖%space%➤
\x1b[0m
[END]

[Execute]
\[\033[0m\]\n
\[\033[38;5;219m\]❖
%space%\u@\h
%space%|%space%\w
%space%❖%space%➤
\[\033[0m\]%space%
[END]

