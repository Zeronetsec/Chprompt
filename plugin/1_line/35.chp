# https://github.com/Zeronetsec/Chprompt

[Preview]
\x1b[0m\n
\x1b[31m$(command whoami)
\x1b[m@
\x1b[34m$(command hostname)
\x1b[m:
\x1b[32m
~/$(command basename "$(pwd)")
\x1b[0m
$(if [[ "${EUID}" -eq 0 ]]; then echo '#'; else echo '$'; fi)
[END]

[Execute]
\[\033[0m\]\n
\[\033[31m\]\u
\[\033[m\]@
\[\033[34m\]\h
\[\033[m\]:
\[\033[32m\]\w
\[\033[0m\]\$
%space%
[END]

