# https://github.com/Zeronetsec/Chprompt

[Preview]
\033[0m\n
\033[32m$(command whoami)@$(command hostname)
\033[0m:
\033[34m~/$(command basename "$(pwd)")
\033[0m%space%
$(if [[ "$EUID" -eq 0 ]]; then echo '#'; else echo '$'; fi)
[END]

[Execute]
\[\033[0m\]\n
\[\033[32m\]\u@\h
\[\033[0m\]:
\[\033[34m\]\w
\[\033[0m\]
%space%\$
%space%
[END]

