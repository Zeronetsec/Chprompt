[Preview]
\033[0m\n
\033[1;31m$(command whoami)
\033[0m@
\033[1;36m$(command hostname)
\033[0m:
\033[1;33m~/$(command basename "$(pwd)")
\033[0m
%space%→
[END]

[Execute]
