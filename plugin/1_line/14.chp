# https://github.com/Zeronetsec/Chprompt

[Preview]
\033[0m\n
\033[1;31m
$(command whoami)@$(command hostname)
\033[0m:
\033[1;34m~/$(command basename "$(pwd)")
\033[0m
$(if [[ "$EUID" -eq 0 ]]; then echo '#'; else echo '$'; fi)
[END]

[Execute]
\[\033[0m\]\n
\[\033[1;31m\]\u@\h
\[\033[0m\]:
\[\033[1;34m\]\w
\[\033[0m\]\$
%space%
[END]

